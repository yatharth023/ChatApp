// ChatApp Prisma schema
// - PostgreSQL specific features (Jsonb, tsvector via raw migration)
// - All FKs cascade on user delete; messages soft-delete for audit / expiry
// - UUIDs are generated by Postgres via dbgenerated to keep clients honest

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
  // `native` covers local dev (macOS/Windows/Linux). The additional targets
  // cover common deploy images: Render / Fly / Railway (debian) and Alpine
  // (alpine) so `prisma generate` produces the right engine binary.
  binaryTargets   = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username      String    @unique @db.VarChar(32)
  email         String    @unique @db.VarChar(254)
  passwordHash  String    @db.VarChar(120)
  avatarUrl     String?   @db.VarChar(1024)
  bio           String?   @db.VarChar(280)
  isOnline      Boolean   @default(false)
  lastSeenAt    DateTime? @db.Timestamptz(6)
  tokenVersion  Int       @default(0)
  deletedAt     DateTime? @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)

  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  blocksInitiated  BlockedUser[]  @relation("Blocker")
  blocksReceived   BlockedUser[]  @relation("Blocked")
  friendshipsA     Friendship[]   @relation("FriendshipUserA")
  friendshipsB     Friendship[]   @relation("FriendshipUserB")
  friendshipsInitiated Friendship[] @relation("FriendshipInitiator")
  refreshTokens    RefreshToken[]
  sessions         UserSession[]

  @@index([username])
  @@index([email])
  @@map("users")
}

// Friendship model — undirected relationship stored once per pair.
// (userAId, userBId) is canonically ordered with userAId < userBId, so the
// pair uniqueness constraint prevents duplicates regardless of who initiates.
// `initiatorId` records who sent the original request so the recipient can
// distinguish "incoming" from "outgoing" pending requests.
model Friendship {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userAId      String            @db.Uuid
  userBId      String            @db.Uuid
  initiatorId  String            @db.Uuid
  status       FriendshipStatus  @default(PENDING)
  createdAt    DateTime          @default(now()) @db.Timestamptz(6)
  respondedAt  DateTime?         @db.Timestamptz(6)

  userA     User @relation("FriendshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User @relation("FriendshipUserB", fields: [userBId], references: [id], onDelete: Cascade)
  initiator User @relation("FriendshipInitiator", fields: [initiatorId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
  @@index([userAId, status])
  @@index([userBId, status])
  @@index([initiatorId])
  @@map("friendships")
}

model RefreshToken {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @db.Uuid
  jti        String   @unique @db.VarChar(128)
  tokenHash  String   @db.VarChar(120)
  deviceInfo String?  @db.VarChar(256)
  ip         String?  @db.VarChar(64)
  expiresAt  DateTime @db.Timestamptz(6)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model UserSession {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid
  refreshJti  String   @unique @db.VarChar(128)
  userAgent   String?  @db.VarChar(512)
  ip          String?  @db.VarChar(64)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  lastUsedAt  DateTime @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

model BlockedUser {
  blockerId String   @db.Uuid
  blockedId String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocked_users")
}

model Message {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientMessageId   String?       @db.Uuid
  senderId          String        @db.Uuid
  receiverId        String        @db.Uuid
  roomId            String        @db.VarChar(96)
  encryptedPayload  String        @db.Text
  iv                String        @db.VarChar(64)
  mediaUrl          String?       @db.VarChar(1024)
  mediaType         String?       @db.VarChar(24)
  thumbnail         String?       @db.VarChar(1024)
  fileSize          Int?
  status            MessageStatus @default(SENT)
  replyToMessageId  String?       @db.Uuid
  reactions         Json          @default("[]")
  editedAt          DateTime?     @db.Timestamptz(6)
  deletedAt         DateTime?     @db.Timestamptz(6)
  expiresAt         DateTime?     @db.Timestamptz(6)
  createdAt         DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime      @updatedAt @db.Timestamptz(6)

  sender    User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver  User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  replyTo   Message? @relation("Replies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies   Message[] @relation("Replies")

  @@unique([senderId, clientMessageId], map: "messages_sender_client_message_id_key")
  @@index([roomId, createdAt(sort: Desc)])
  @@index([receiverId, status])
  @@index([expiresAt])
  @@index([replyToMessageId])
  @@map("messages")
}
