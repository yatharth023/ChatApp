# ---------- App ----------
NODE_ENV=development
PORT=4000
API_PREFIX=/api

# ---------- CORS ----------
CORS_ORIGIN=http://localhost:5173
COOKIE_DOMAIN=localhost

# ---------- Database ----------
DATABASE_URL="postgresql://chatapp:chatapp@localhost:5432/chatapp?schema=public"

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379

# ---------- Auth ----------
# Generate with: node -e 'console.log(require("crypto").randomBytes(64).toString("hex"))'
JWT_ACCESS_SECRET=replace-with-at-least-32-random-chars
JWT_REFRESH_SECRET=replace-with-at-least-32-random-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
BCRYPT_COST=12

# ---------- Cloudinary ----------
# Create a free account at https://cloudinary.com/ and paste the credentials
# from the dashboard. Leave blank to disable media uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=chatapp
CLOUDINARY_UPLOAD_PRESET=chatapp-media

# ---------- Rate limits ----------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
LOGIN_RATE_LIMIT_MAX=8

# ---------- Cron ----------
EXPIRY_CRON=*/1 * * * *
