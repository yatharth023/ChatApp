# ============================================================================
# ChatApp .gitignore
# ============================================================================
# Anything committed here is fetched by every collaborator and every CI
# runner. Keep secrets (JWT / Cloudinary / DB creds), generated artefacts,
# machine-specific caches, and OS junk out of the repo. `.env.example` files
# are the public template; the real `.env` values must stay local.
# ============================================================================

# ---------- Dependencies -----------------------------------------------------
node_modules/
**/node_modules/
.pnpm-store/
.yarn/
.npm/
.pnp.*
jspm_packages/

# ---------- Build output -----------------------------------------------------
dist/
build/
out/
*.tsbuildinfo

# Vite
.vite/
**/.vite/

# Prisma-generated client (regenerated by `prisma generate`)
**/.prisma/
backend/prisma/generated/

# ---------- Environment / secrets --------------------------------------------
# Real environment files must never be committed. Templates are tracked.
.env
.env.*
!.env.example
!*/.env.example

# Ad-hoc secret files sometimes dropped next to .env
secrets.*
*.pem
*.key
*.crt
*.p12
*.pfx
nginx/certs/

# ---------- Logs -------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# ---------- Testing / coverage -----------------------------------------------
coverage/
.nyc_output/
*.lcov
playwright-report/
test-results/
junit.xml

# ---------- Caches -----------------------------------------------------------
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.turbo/
.swc/
.rollup.cache/
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
.node_repl_history

# ---------- Editors / IDEs ---------------------------------------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.example.json
.idea/
*.iml
*.ipr
*.iws
.fleet/
.zed/
*.sublime-project
*.sublime-workspace
.history/
nbproject/
.project
.classpath
.settings/

# ---------- OS files ---------------------------------------------------------
.DS_Store
.DS_Store?
._*
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------- Docker / infra ---------------------------------------------------
docker-compose.override.yml
docker-compose.override.yaml
.docker/

# ---------- Local database + volumes -----------------------------------------
*.sqlite
*.sqlite3
*.db
pgdata/
redisdata/
dump.rdb
*.dump
*.sql.gz

# ---------- Uploads / user content -------------------------------------------
uploads/
tmp/
temp/

# ---------- Runtime debug artefacts ------------------------------------------
pids/
*.pid
*.seed
*.pid.lock
core
core.*

# ---------- Misc -------------------------------------------------------------
.env.decrypted
.tern-port
