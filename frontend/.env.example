# Vite proxies /api and /socket.io to VITE_API_ORIGIN in dev.
VITE_API_ORIGIN=http://localhost:4000

# Empty in dev — same origin, proxied by Vite. In prod point at your API host.
VITE_API_BASE=/api
VITE_SOCKET_URL=

# Cloudinary — needed only for direct client uploads (the backend signs).
VITE_CLOUDINARY_CLOUD_NAME=oxvstcvi